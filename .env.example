# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── LLM (required) ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here

# Model to use (default: minimax/minimax-m1).
# Use a model with good function-calling support, e.g.:
#   openai/gpt-4o-mini
#   google/gemini-flash-1.5
#   anthropic/claude-haiku-20240307
MAAT_MODEL=openai/gpt-4o-mini

# ── IMAP talent (optional) ─────────────────────────────────────────
# If set, MAAT gains email_list / email_read / email_search tools.
# Use an app password, not your account password.
# Gmail: myaccount.google.com → Security → App passwords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=you@gmail.com
IMAP_PASSWORD=your-16-char-app-password
